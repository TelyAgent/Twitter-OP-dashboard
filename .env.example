# Daily sync scheduler (all optional — defaults shown)
# SYNC_HOUR=2
#   hour of day to run (0-23)
# SYNC_MAX_RETRIES=3
#   max retries per source on failure
# SYNC_FETCH_LIMIT=100
#   tweets pulled per source
# SYNC_TOP_ENGAGEMENT=30
#   engagement cutoff
# SYNC_BATCH_MAX=20
#   max sources per run
# SYNC_DELAY_MIN=8000
#   min inter-source delay (ms)
# SYNC_DELAY_MAX=25000
#   max inter-source delay (ms)
